# ── Baileys API Server — Environment Variables ────────────────────────────────
# Copy to .env and customize before running docker compose

# Port exposed on the host (nginx)
EXPOSE_PORT=21465
PORT=21465

# Initial number of worker replicas
INITIAL_REPLICAS=2

# Log level: silent | trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Auto-scaler settings (used by scripts/autoscale.sh)
SESSIONS_PER_WORKER=10
MIN_WORKERS=1
MAX_WORKERS=20
CHECK_INTERVAL=60
